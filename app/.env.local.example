# Supabase — https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key — NEVER expose to client, server-side only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App URL (used for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Places API (New) — job processing runs server-side
PLACES_API_KEY=AIza...

# Outreach SMTP password encryption key (AES-256-GCM). Any random 32+ char string.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OUTREACH_ENCRYPTION_KEY=

# iyzico — Merchant Panel → Ayarlar → API Anahtarları
# Sandbox URL: https://sandbox-api.iyzipay.com — Production: https://api.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Premium fiyatı (TL) — bkz. app/lib/constants.ts PREMIUM_PRICE_TRY
PREMIUM_PRICE_TRY=499
