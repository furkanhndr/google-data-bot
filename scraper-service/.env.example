# Supabase — service role is required to bypass RLS when writing results.
SUPABASE_URL=https://XXXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Proxy (STRONGLY recommended for production — Google blocks datacenter IPs).
# Provider-agnostic: any HTTP/SOCKS proxy URL works. Leave empty to run direct.
# Example (rotating residential): http://user:pass@gateway.provider.com:7000
PROXY_SERVER=

# How many jobs to process at the same time.
JOB_CONCURRENCY=2

# How often to poll for new pending jobs (ms).
POLL_INTERVAL_MS=5000

# Run the browser headless (true) or headed (false, needs a display).
HEADLESS=true

# Automatically crawl websites for emails after a job completes.
AUTO_ENRICH=true
ENRICH_CONCURRENCY=5
